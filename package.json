{
  "name": "kmp-test-runner",
  "version": "0.6.1",
  "type": "module",
  "description": "Parallel test runner for KMP and Android Gradle projects",
  "homepage": "https://github.com/oscardlfr/kmp-test-runner#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oscardlfr/kmp-test-runner.git"
  },
  "bugs": {
    "url": "https://github.com/oscardlfr/kmp-test-runner/issues"
  },
  "keywords": [
    "kotlin",
    "kotlin-multiplatform",
    "kmp",
    "android",
    "gradle",
    "test-runner",
    "parallel-tests",
    "coverage"
  ],
  "author": "oscardlfr",
  "bin": {
    "kmp-test": "bin/kmp-test.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "shellcheck": "shellcheck scripts/sh/*.sh scripts/sh/lib/*.sh"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@vitest/coverage-v8": "^2.1.0",
    "js-tiktoken": "^1.0.21",
    "vitest": "^2.1.0"
  }
}
